# ═══════════════════════════════════════════
# STORM ID Test App — Environment Configuration
# ═══════════════════════════════════════════
# Copy to .env if you want to customize:
#   cp .env.example .env
# ═══════════════════════════════════════════

# Server port
PORT=5173

# Hydra internal URL (from within Docker network, server-side calls)
HYDRA_PUBLIC_URL=http://hydra:4444

# Session secret (optional — auto-generated if not set, sessions lost on restart)
SESSION_SECRET=
