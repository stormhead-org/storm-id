# ═══════════════════════════════════════════
# STORM ID — Environment Configuration
# ═══════════════════════════════════════════
# Copy to .env and fill in the values:
#   cp .env.example .env
#
# Generate secrets:
#   openssl rand -hex 32  # for system/cookie secrets
#   openssl rand -hex 16  # for Kratos cipher (MUST be 32 hex chars!)
#
# Generate configs after filling .env:
#   bash scripts/generate-config.sh          # production
#   bash scripts/generate-config.sh --dev    # local development
# ═══════════════════════════════════════════

# ── Public URL ─────────────────────────────
# The base URL where storm-id-ui is served (no trailing slash)
# Must be set before running generate-config.sh
PUBLIC_URL=https://id.yourdomain.com

# ── Databases ──────────────────────────────
# Postgres host (use container name for Docker, or external hostname/IP)
POSTGRES_HOST=postgres
POSTGRES_USER=storm
POSTGRES_PASSWORD=<generate: openssl rand -hex 32>

KRATOS_DB=kratos
HYDRA_DB=hydra
KETO_DB=keto

# ── Hydra Secrets ──────────────────────────
# System encryption key (32 bytes → 64 hex chars)
HYDRA_SECRETS_SYSTEM=<generate: openssl rand -hex 32>
# Cookie encryption key (32 bytes → 64 hex chars)
HYDRA_SECRETS_COOKIE=<generate: openssl rand -hex 32>
# Salt for OIDC pairwise subject identifiers (32 bytes → 64 hex chars)
HYDRA_OIDC_PAIRWISE_SALT=<generate: openssl rand -hex 32>

# ── Kratos Secrets ─────────────────────────
# Session cookie encryption key (32 bytes → 64 hex chars)
KRATOS_SECRETS_COOKIE=<generate: openssl rand -hex 32>
# AES cipher key (16 bytes → EXACTLY 32 hex chars!)
KRATOS_SECRETS_CIPHER=<generate: openssl rand -hex 16>

# ── storm-id-ui ─────────────────────────────
# Secret for encrypting Hydra OAuth2 state cookies (32+ chars)
HYDRA_STATE_SECRET=<generate: openssl rand -hex 32>

# ── PKCE ───────────────────────────────────
# Enforce PKCE for all OAuth2 clients (recommended: true for production)
HYDRA_PKCE_ENFORCED=true

# ── Kratos Cookie ──────────────────────────
# Session cookie name (default: ory_kratos_session)
KRATOS_COOKIE_NAME=ory_kratos_session

# ── Ory Next.js SDK ───────────────────────
# SDK URL used by @ory/nextjs middleware and server components.
# For local Docker: http://kratos:4433 (internal network)
NEXT_PUBLIC_ORY_SDK_URL=http://kratos:4433

# ── SMTP (optional — for verification/recovery emails) ──
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME="STORM ID"
